# Doxygen configuration for the AXIAM C++ SDK.
# Generate with:  doxygen Doxyfile   (HTML output lands in docs/html/)

PROJECT_NAME           = "AXIAM C++ SDK"
PROJECT_NUMBER         = 1.0.0-alpha8
PROJECT_BRIEF          = "Authentication, authorization, JWKS & route guards (REST + mTLS)"

OUTPUT_DIRECTORY       = docs
HTML_OUTPUT            = html
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

INPUT                  = include README.md
FILE_PATTERNS          = *.hpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
HAVE_DOT               = NO

# Treat the public headers' triple-slash comments as documentation.
MARKDOWN_SUPPORT       = YES
SORT_MEMBER_DOCS       = NO
